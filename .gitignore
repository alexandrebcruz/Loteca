# dados / saídas / cache (regeneráveis — histórico da Caixa, preços).
# EXCEÇÃO: data/analise/ é versionado (checkpoints + relatórios das análises).
data/*
!data/analise/

# ambientes e bytecode Python
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class

# logs e artefatos de execução
*.log
*.out
_game.png
_home.png

# config local do harness / editor
.claude/
.vscode/
.idea/

# locks/backups dos apelidos (gerados pelos auditores)
*.lock
*.bak
*.bak.*

# data/analise é 100% versionado: esta negação final vence as regras globais
# acima (*.log, *.png, *.bak, *.lock…) para QUALQUER arquivo dentro da pasta.
!data/analise/**
